# Supabase Postgres / Prisma
# Use the pooled Supabase connection string for runtime queries.
DATABASE_URL="postgresql://postgres.qyzfftjpjiuqxlmyskwb:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct Supabase connection string for Prisma schema pushes/migrations.
DIRECT_URL="postgresql://postgres.qyzfftjpjiuqxlmyskwb:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Custom app session signing secret. Generate a long random value for production.
AUTH_SECRET="replace-with-a-long-random-secret"

# Supabase Storage for uploaded documents/tender files.
SUPABASE_URL="https://qyzfftjpjiuqxlmyskwb.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="documents"

# AI provider routing. "auto" uses OpenAI first when OPENAI_API_KEY exists,
# then Anthropic, then Local Knowledge Mode.
AI_PROVIDER="auto"

# Optional: real OpenAI generation.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"

# Optional: real Claude generation.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
ANTHROPIC_OPUS_MODEL="claude-opus-4-7"

# Backward-compatible model env. Prefer OPENAI_MODEL / ANTHROPIC_MODEL above.
ATLASVAULT_MODEL="gpt-5.5"
